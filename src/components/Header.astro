---
import { fetchCategories } from '../lib/api';

const categories = await fetchCategories();
const topCats = categories.slice(0, 6);
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo-link">
      <img src="/cb-icon.png" alt="CB" width="44" height="44" style="height:44px;width:auto;flex-shrink:0" fetchpriority="high" />
      <span class="logo-text">Curitiba<span class="logo-accent"> Blog</span></span>
    </a>

    <button class="menu-toggle" id="menu-toggle" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <nav class="site-nav" id="site-nav">
      <a href="/">Início</a>
      <a href="/sobre">Sobre</a>
      {topCats.map(cat => (
        <a href={`/categoria/${cat.slug}`}>{cat.name}</a>
      ))}
      <a href="/contato">Contato</a>
      <a href="https://area.curitibablog.com.br/entrar" class="nav-entrar">Entrar</a>
      <a href="https://area.curitibablog.com.br/cadastro" class="nav-cta">Cadastrar</a>
    </nav>

    <button id="theme-toggle" class="theme-toggle" aria-label="Alternar tema claro/escuro" title="Alternar tema">
      <i id="theme-icon" class="fa-solid fa-moon"></i>
    </button>
  </div>
</header>
