---
import { fetchCategories } from '../lib/api';

const categories = await fetchCategories();
const topCats = categories.slice(0, 6);
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo-link">
      <img src="/logo.png" alt="CuritibaBlog" style="height:44px;width:auto;flex-shrink:0" />
    </a>

    <button class="menu-toggle" id="menu-toggle" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <nav class="site-nav" id="site-nav">
      <a href="/">Início</a>
      {topCats.map(cat => (
        <a href={`/categoria/${cat.slug}`}>{cat.name}</a>
      ))}
      <a href="https://curitibasoftware.com.br" target="_blank" rel="noopener" class="nav-cta">
        Fale Conosco
      </a>
    </nav>
  </div>
</header>
