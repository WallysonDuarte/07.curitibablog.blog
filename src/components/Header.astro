---
import { fetchCategories } from '../lib/api';

const categories = await fetchCategories();
const topCats = categories.slice(0, 6);
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo-link">
      <img src="/cb-icon.png" alt="CB" width="44" height="44" style="height:44px;width:auto;flex-shrink:0" fetchpriority="high" />
      <span class="logo-text">Curitiba<span class="logo-accent"> Blog</span></span>
    </a>

    <button class="menu-toggle" id="menu-toggle" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <nav class="site-nav" id="site-nav">
      <a href="/">Início</a>
      <a href="/sobre">Sobre</a>
      {topCats.map(cat => (
        <a href={`/categoria/${cat.slug}`}>{cat.name}</a>
      ))}
      <a href="/contato">Contato</a>
      <div class="nav-dropdown">
        <button class="nav-dropdown-toggle" aria-expanded="false">Legal <i class="fa-solid fa-chevron-down" style="font-size:.6rem"></i></button>
        <div class="nav-dropdown-menu">
          <a href="/privacidade">Política de Privacidade</a>
          <a href="/termos">Termos de Uso</a>
        </div>
      </div>
      <a href="https://chat.whatsapp.com/FXw6emOLBtIHOusvzzz1pS" target="_blank" rel="noopener noreferrer" class="nav-wpp" title="Entre no grupo WhatsApp">
        <i class="fa-brands fa-whatsapp"></i> Grupo
      </a>
      <a href="https://area.curitibablog.com.br/entrar" class="nav-entrar">Entrar</a>
      <a href="https://area.curitibablog.com.br/cadastro" class="nav-cta">Cadastrar</a>
    </nav>

    <button id="theme-toggle" class="theme-toggle" aria-label="Alternar tema claro/escuro" title="Alternar tema">
      <i id="theme-icon" class="fa-solid fa-moon"></i>
    </button>
  </div>
</header>

<script>
  // Dropdown Legal
  const dropdownWrapper = document.querySelector('.nav-dropdown');
  const dropdownToggle = document.querySelector('.nav-dropdown-toggle');
  if (dropdownToggle && dropdownWrapper) {
    dropdownToggle.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = dropdownWrapper.classList.toggle('open');
      dropdownToggle.setAttribute('aria-expanded', String(open));
    });
    document.addEventListener('click', () => {
      dropdownWrapper.classList.remove('open');
      dropdownToggle.setAttribute('aria-expanded', 'false');
    });
  }
</script>
