---
import { fetchCategories } from '../lib/api';

const categories = await fetchCategories();
const topCats = categories.slice(0, 6);
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo-link">
      <svg width="28" height="28" viewBox="0 0 32 32" style="flex-shrink:0">
        <rect width="32" height="32" rx="8" fill="#4ecdc4"/>
        <text x="16" y="22" font-size="18" text-anchor="middle" fill="white" font-family="sans-serif" font-weight="bold">C</text>
      </svg>
      LevelUp<span class="logo-accent">Dev</span>
    </a>

    <button class="menu-toggle" id="menu-toggle" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <nav class="site-nav" id="site-nav">
      <a href="/">Início</a>
      {topCats.map(cat => (
        <a href={`/categoria/${cat.slug}`}>{cat.name}</a>
      ))}
      <a href="https://curitibasoftware.com.br" target="_blank" rel="noopener" class="nav-cta">
        Fale Conosco
      </a>
    </nav>
  </div>
</header>
