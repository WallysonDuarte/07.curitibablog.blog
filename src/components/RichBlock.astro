---
import type { PostBlock } from '../lib/types';

interface Props {
  block: PostBlock;
  blockIdx: number;
}

const { block, blockIdx } = Astro.props;
const d = block.data ?? {};

function fbEmbedUrl(pageUrl: string): string {
  return `https://www.facebook.com/plugins/page.php?href=${encodeURIComponent(pageUrl)}&tabs=posts&width=500&height=600&small_header=false&adapt_container_width=true&hide_cover=false&show_facepile=true`;
}
function fbPostEmbedUrl(postUrl: string): string {
  const isVideo = postUrl.includes('/videos/') || postUrl.includes('watch/?v=');
  const plugin = isVideo ? 'video' : 'post';
  return `https://www.facebook.com/plugins/${plugin}.php?href=${encodeURIComponent(postUrl)}&width=500&show_text=true`;
}
---

<div class="block-wrap">
  {block.label && <p class="block-label">{block.label}</p>}

  {/* ── MAP ───────────────────────────────────── */}
  {block.type === 'map' && d.embedUrl && (
    <div class="block-map">
      <iframe
        src={d.embedUrl}
        loading="lazy"
        allowfullscreen
        title={d.address || 'Mapa'}
        referrerpolicy="no-referrer-when-downgrade"
      />
      {d.address && <p class="map-address">📍 {d.address}</p>}
      {d.directionsUrl && (
        <a href={d.directionsUrl} target="_blank" rel="noopener" class="map-directions">
          <i class="fa-solid fa-location-dot"></i> Como chegar
        </a>
      )}
    </div>
  )}

  {/* ── GALLERY ───────────────────────────────── */}
  {block.type === 'gallery' && d.images?.length > 0 && (
    <div class="block-gallery">
      <div class="gallery-grid">
        {d.images.map((img: { url: string; caption?: string }) => (
          <div
            class="gallery-img"
            data-lightbox={img.url}
            data-caption={img.caption || ''}
            role="button"
            tabindex="0"
            aria-label={img.caption || 'Ver foto'}
          >
            <img src={img.url} alt={img.caption || ''} loading="lazy" decoding="async" />
            {img.caption && <span class="gallery-img-caption">{img.caption}</span>}
          </div>
        ))}
      </div>
    </div>
  )}

  {/* ── REVIEWS ───────────────────────────────── */}
  {block.type === 'reviews' && (d.reviews?.length > 0 || d.items?.length > 0) && (
    <div class="block-reviews">
      {d.source && <p class="review-source">⭐ Avaliações — {d.source}</p>}
      <div class="reviews-list">
        {(d.reviews ?? d.items).map((r: { author: string; rating: number; text: string; date?: string; avatar?: string }) => (
          <div class="review-card">
            <div class="review-header">
              <span class="review-author">{r.author}</span>
              <span class="review-stars">{'★'.repeat(Math.min(5, r.rating))}{'☆'.repeat(Math.max(0, 5 - r.rating))}</span>
            </div>
            <p class="review-text">{r.text}</p>
            {r.date && <p class="review-date">{r.date}</p>}
          </div>
        ))}
      </div>
    </div>
  )}

  {/* ── INFO ──────────────────────────────────── */}
  {block.type === 'info' && d.items?.length > 0 && (
    <div class="block-info">
      <div class="info-list">
        {d.items.map((item: { icon?: string; label: string; value: string }) => (
          <div class="info-item">
            {item.icon && (
              <span class="info-icon"><i class={`fa-solid ${item.icon}`}></i></span>
            )}
            <div>
              <p class="info-label">{item.label}</p>
              <p class="info-value">{item.value}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  {/* ── LINKS ─────────────────────────────────── */}
  {block.type === 'links' && (d.links?.length > 0 || d.items?.length > 0) && (
    <div class="block-links">
      <div class="links-list">
        {(d.links ?? d.items).map((link: { label: string; value?: string; url: string; icon?: string }) => (
          <a href={link.url} target="_blank" rel="noopener noreferrer" class="link-item">
            {link.icon && (
              <span class="link-icon"><i class={`fa-solid ${link.icon}`}></i></span>
            )}
            <span class="link-text">
              <span class="link-label">{link.label}</span>
              {link.value && <span class="link-value">{link.value}</span>}
            </span>
            <i class="fa-solid fa-arrow-up-right-from-square" style="flex-shrink:0;font-size:.75rem;color:var(--text-light)"></i>
          </a>
        ))}
      </div>
    </div>
  )}

  {/* ── VIDEO ─────────────────────────────────── */}
  {block.type === 'video' && d.embedUrl && (
    <div class="block-video">
      <div class="video-wrap">
        <iframe
          src={d.embedUrl}
          loading="lazy"
          allowfullscreen
          title={d.caption || 'Vídeo'}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        />
      </div>
      {d.caption && <p class="video-caption">{d.caption}</p>}
    </div>
  )}

  {/* ── YOUTUBE GALLERY ───────────────────────── */}
  {block.type === 'youtube-gallery' && d.videos?.length > 0 && (
    <div class="block-yt-gallery">
      <div class="yt-grid">
        {d.videos.map((v: { embedUrl?: string; videoId?: string; title?: string }) => {
          const src = v.embedUrl ?? (v.videoId ? `https://www.youtube.com/embed/${v.videoId}` : null);
          return src ? (
            <div class="yt-item">
              <div class="yt-wrap">
                <iframe
                  src={src}
                  loading="lazy"
                  allowfullscreen
                  title={v.title || 'Vídeo'}
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                />
              </div>
              {v.title && <p class="yt-title">{v.title}</p>}
            </div>
          ) : null;
        })}
      </div>
    </div>
  )}

  {/* ── INSTAGRAM ─────────────────────────────── */}
  {block.type === 'instagram' && (
    <div class="block-instagram">
      {d.posts?.length > 0 ? (
        <div>
          {d.description && <p style="margin-bottom:.8rem;font-size:.9rem;">{d.description}</p>}
          {(d.handle || d.username) && (
            <p style="font-size:.78rem;color:var(--text-light);margin-bottom:.7rem">
              @{d.handle ?? d.username}
            </p>
          )}
          <div class="ig-card-grid">
            {d.posts.map((post: { shortcode: string; caption?: string }) => (
              <a
                class="ig-card"
                href={`https://www.instagram.com/p/${post.shortcode}/`}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={post.caption || 'Ver no Instagram'}
              >
                <i class="fa-brands fa-instagram ig-card-icon"></i>
                {post.caption && <p class="ig-card-caption">{post.caption}</p>}
                <span class="ig-card-link">Ver no Instagram →</span>
              </a>
            ))}
          </div>
        </div>
      ) : d.tag ? (
        <div class="instagram-placeholder">
          <i class="fa-brands fa-instagram"></i>
          <p style="margin-top:.5rem">#{d.tag}</p>
          {d.description && <p style="font-size:.85rem;opacity:.8;margin-top:.3rem">{d.description}</p>}
        </div>
      ) : (d.username || d.handle) ? (
        <div class="instagram-placeholder">
          <i class="fa-brands fa-instagram"></i>
          <p style="margin-top:.5rem">@{d.username ?? d.handle}</p>
          {d.label && <p style="font-size:.85rem;opacity:.8;margin-top:.3rem">{d.label}</p>}
          <a href={`https://www.instagram.com/${d.username ?? d.handle}/`} target="_blank" rel="noopener" style="margin-top:.6rem;font-size:.85rem;color:#fff;text-decoration:underline">Ver perfil no Instagram →</a>
        </div>
      ) : null}
    </div>
  )}

  {/* ── X / TWITTER ───────────────────────────── */}
  {block.type === 'x' && (
    <div class="block-x">
      {(d.posts?.length > 0 || d.tweets?.length > 0) ? (
        <div>
          {d.description && <p style="margin-bottom:.8rem;font-size:.9rem;">{d.description}</p>}
          <div class="tweet-cards">
            {(d.posts ?? d.tweets).map((post: { tweetId?: string; postId?: string; text?: string; caption?: string }) => {
              const id = post.tweetId ?? post.postId;
              const handle = d.username ?? d.handle ?? 'x';
              const text = post.text || post.caption || '';
              return id ? (
                <div class="tweet-card">
                  <div class="tweet-header">
                    <i class="fa-brands fa-x-twitter"></i>
                    <span class="tweet-handle">@{handle}</span>
                  </div>
                  {text && <p class="tweet-text">{text}</p>}
                  <a
                    href={`https://x.com/${handle}/status/${id}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="tweet-link"
                  >
                    Ver post completo no X →
                  </a>
                </div>
              ) : null;
            })}
          </div>
        </div>
      ) : (d.username || d.handle) ? (
        <div class="instagram-placeholder" style="background:#1d1d1d">
          <i class="fa-brands fa-x-twitter"></i>
          <p style="margin-top:.5rem">@{d.username ?? d.handle}</p>
          {d.description && <p style="font-size:.85rem;opacity:.8;margin-top:.3rem">{d.description}</p>}
          <a href={`https://x.com/${d.username ?? d.handle}`} target="_blank" rel="noopener" style="margin-top:.6rem;font-size:.85rem;color:#fff;text-decoration:underline">Ver perfil no X →</a>
        </div>
      ) : null}
    </div>
  )}

  {/* ── REELS ──────────────────────────────────── */}
  {block.type === 'reels' && (
    <div class="block-instagram">
      {(d.posts?.length > 0 || d.reels?.length > 0) ? (
        <div>
          {d.description && <p style="margin-bottom:.8rem;font-size:.9rem;">{d.description}</p>}
          {(d.handle || d.username) && (
            <p style="font-size:.78rem;color:var(--text-light);margin-bottom:.7rem">
              @{d.handle ?? d.username}
            </p>
          )}
          <div class="ig-card-grid">
            {(d.posts ?? d.reels).map((post: { shortcode: string; caption?: string }) => (
              <a
                class="ig-card"
                href={`https://www.instagram.com/reel/${post.shortcode}/`}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={post.caption || 'Ver Reel no Instagram'}
              >
                <i class="fa-solid fa-play ig-card-icon"></i>
                {post.caption && <p class="ig-card-caption">{post.caption}</p>}
                <span class="ig-card-link">Ver Reel →</span>
              </a>
            ))}
          </div>
        </div>
      ) : (d.username || d.handle) ? (
        <div class="instagram-placeholder">
          <i class="fa-brands fa-instagram"></i>
          <p style="margin-top:.5rem">Reels — @{d.username ?? d.handle}</p>
          <a href={`https://www.instagram.com/${d.username ?? d.handle}/reels/`} target="_blank" rel="noopener" style="margin-top:.6rem;font-size:.85rem;color:#fff;text-decoration:underline">Ver Reels no Instagram →</a>
        </div>
      ) : null}
    </div>
  )}

  {/* ── FACEBOOK ──────────────────────────────── */}
  {block.type === 'facebook' && (
    <div class="block-facebook">
      {d.posts?.length > 0 ? (
        d.posts.map((post: { postUrl: string; caption?: string }) => (
          <div class="fb-wrap">
            {post.caption && <p style="margin-bottom:.6rem;font-size:.9rem;">{post.caption}</p>}
            <iframe
              src={fbPostEmbedUrl(post.postUrl)}
              loading="lazy"
              title="Post do Facebook"
              allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
              allowfullscreen
            />
          </div>
        ))
      ) : d.pageUrl ? (
        <div class="fb-wrap">
          {d.title && <p style="margin-bottom:.6rem;font-size:.9rem;font-weight:600">{d.title}</p>}
          <iframe
            src={fbEmbedUrl(d.pageUrl)}
            loading="lazy"
            title="Página do Facebook"
            allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
            allowfullscreen
          />
        </div>
      ) : (d.handle || d.username) ? (
        <div class="fb-placeholder">
          <i class="fa-brands fa-facebook"></i>
          <p style="margin-top:.5rem;font-weight:600">@{d.handle ?? d.username}</p>
          {d.label && <p style="font-size:.85rem;opacity:.85;margin-top:.3rem">{d.label}</p>}
          <a href={`https://www.facebook.com/${d.handle ?? d.username}/`} target="_blank" rel="noopener">Ver página no Facebook →</a>
        </div>
      ) : null}
    </div>
  )}
</div>
