---
import { formatDate, toSlug, ratingColor } from '../lib/utils';
import type { BlogPostRatings } from '../lib/types';

const API_BASE = 'https://api.curitibasoftware.com.br';

interface Props {
  title: string;
  summary: string;
  slug: string;
  publishedAt?: string;
  createdAt: string;
  category: string;
  categories?: string[];
  tags: string[];
  coverImageUrl?: string;
  coverImageKey?: string;
  views: number;
  compact?: boolean;
  ratings?: BlogPostRatings;
}

const {
  title, summary, slug, publishedAt, createdAt, category,
  categories, tags, coverImageUrl, coverImageKey, views, compact = false, ratings,
} = Astro.props;

const imgSrc = `${API_BASE}/api/blog/cover/${slug}`;
const imgWebP = `${imgSrc}?format=webp&w=600`;
const imgFallback = `${imgSrc}?w=600`;

const displayCat = categories?.length ? categories[0] : category;
const date = formatDate(publishedAt || createdAt);
const postUrl = `/${slug}`;
---

<article class={`post-card ${compact ? 'post-card-compact' : ''}`} data-tags={tags?.join(',') || ''} data-sort-date={publishedAt || createdAt} data-sort-title={title.toLowerCase()}>
  <a href={postUrl} tabindex="-1">
    <div class="post-card-image" aria-hidden="true">
      <picture>
        <source type="image/webp" srcset={imgWebP} />
        <img src={imgFallback} alt="" width="600" height="315" loading="lazy" decoding="async" />
      </picture>
      {displayCat && <span class="card-category">{displayCat}</span>}
      {ratings && <span class="card-rating" style={`background:${ratingColor(ratings.media)}`}>{ratings.media.toFixed(1)}</span>}
    </div>
  </a>
  <div class="post-card-body">
    <h2><a href={postUrl}>{title}</a></h2>
    {!compact && <p>{summary}</p>}
    <div class="card-meta">
      <span>📅 {date}</span>
      {views > 0 && <span>👁 {views.toLocaleString('pt-BR')}</span>}
    </div>
    {!compact && tags?.length > 0 && (
      <div class="card-tags">
        {tags.slice(0, 3).map(tag => (
          <a href={`/tag/${toSlug(tag)}`} class="card-tag" onclick="event.stopPropagation()">#{tag}</a>
        ))}
      </div>
    )}
  </div>
</article>
