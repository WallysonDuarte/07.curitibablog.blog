---
import { fetchCategories } from '../lib/api';

const categories = await fetchCategories();
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/" class="logo-link">
        <img src="/logo.png" alt="CuritibaBlog" style="height:40px;width:auto" />
      </a>
      <p style="margin-top:.8rem">
        Guias completos sobre parques, pontos turísticos, restaurantes e tudo o que fazer em Curitiba.
        Dicas locais, fotos e roteiros para você aproveitar a melhor cidade do Sul.
      </p>
    </div>

    <div class="footer-col">
      <h4>Categorias</h4>
      <ul>
        {categories.slice(0, 8).map(cat => (
          <li><a href={`/categoria/${cat.slug}`}>{cat.name}</a></li>
        ))}
        <li><a href="/">Ver todas</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Links</h4>
      <ul>
        <li><a href="/">Blog</a></li>
        <li><a href="https://curitibasoftware.com.br" target="_blank" rel="noopener">Curitiba Software</a></li>
        <li><a href="/rss.xml">Feed RSS</a></li>
      </ul>
    </div>
  </div>

  <!-- NEWSLETTER -->
  <div class="footer-newsletter">
    <h4>Newsletter</h4>
    <p>Receba novidades sobre Curitiba direto no seu e-mail</p>
    <div id="nl-cooldown" style="display:none" class="nl-cooldown-msg">
      <span>✅ Inscrição realizada! Próximo envio disponível em <strong id="nl-timer"></strong></span>
    </div>
    <form id="nl-form" class="nl-form" novalidate>
      <!-- Honeypot oculto -->
      <input type="text" name="website" id="nl-honeypot" style="display:none;position:absolute;left:-9999px" tabindex="-1" autocomplete="off">
      <input type="email" id="nl-email" name="email" placeholder="Seu melhor e-mail" required maxlength="254" autocomplete="email">
      <div class="nl-captcha-row">
        <label id="nl-captcha-label"></label>
        <input type="number" id="nl-captcha-input" placeholder="?" required min="0" max="99" autocomplete="off">
      </div>
      <button type="submit" id="nl-btn">Inscrever</button>
    </form>
    <p id="nl-msg" class="nl-msg" style="display:none"></p>
  </div>

  <div class="footer-bottom">
    <p>&copy; {year} CuritibaBlog — Todos os direitos reservados</p>
  </div>
</footer>

<script>
(function() {
  var COOLDOWN_KEY = 'nl_cooldown_until';
  var API = 'https://api.curitibasoftware.com.br/api/newsletter/subscribe';
  var captchaExp = 0;

  function genCaptcha() {
    var a = Math.floor(Math.random() * 15) + 1;
    var b = Math.floor(Math.random() * 15) + 1;
    captchaExp = a + b;
    var lbl = document.getElementById('nl-captcha-label');
    var inp = document.getElementById('nl-captcha-input');
    if (lbl) lbl.textContent = 'Quanto é ' + a + ' + ' + b + '?';
    if (inp) inp.value = '';
  }

  function fmtTime(secs) {
    var m = Math.floor(secs / 60);
    var s = secs % 60;
    return m + 'min ' + (s < 10 ? '0' : '') + s + 's';
  }

  function startTimer(untilMs) {
    var form = document.getElementById('nl-form');
    var cooldownDiv = document.getElementById('nl-cooldown');
    var timerEl = document.getElementById('nl-timer');
    if (form) form.style.display = 'none';
    if (cooldownDiv) cooldownDiv.style.display = 'block';

    var tick = setInterval(function() {
      var rem = Math.ceil((untilMs - Date.now()) / 1000);
      if (rem <= 0) {
        clearInterval(tick);
        if (form) form.style.display = '';
        if (cooldownDiv) cooldownDiv.style.display = 'none';
        genCaptcha();
      } else {
        if (timerEl) timerEl.textContent = fmtTime(rem);
      }
    }, 1000);
    var rem0 = Math.ceil((untilMs - Date.now()) / 1000);
    if (timerEl) timerEl.textContent = fmtTime(rem0);
  }

  function showMsg(text, ok) {
    var el = document.getElementById('nl-msg');
    if (!el) return;
    el.textContent = text;
    el.style.display = 'block';
    el.style.color = ok ? '#2ecc71' : '#ff6b6b';
  }

  function init() {
    genCaptcha();

    var until = parseInt(localStorage.getItem(COOLDOWN_KEY) || '0');
    if (until > Date.now()) startTimer(until);

    var form = document.getElementById('nl-form');
    if (!form) return;
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var honey = document.getElementById('nl-honeypot').value;
      var email = document.getElementById('nl-email').value.trim();
      var captchaVal = parseInt(document.getElementById('nl-captcha-input').value);
      var btn = document.getElementById('nl-btn');

      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        showMsg('Informe um e-mail válido', false); return;
      }
      if (captchaVal !== captchaExp) {
        showMsg('Resposta do captcha incorreta. Tente novamente.', false);
        genCaptcha(); return;
      }

      btn.disabled = true;
      btn.textContent = 'Enviando...';

      fetch(API, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email, website: honey || undefined })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        showMsg(data.message || 'Processado', data.success);
        btn.disabled = false;
        btn.textContent = 'Inscrever';
        if (data.success) {
          var until = Date.now() + 10 * 60 * 1000;
          localStorage.setItem(COOLDOWN_KEY, String(until));
          startTimer(until);
        } else {
          genCaptcha();
        }
      })
      .catch(function() {
        showMsg('Erro ao processar. Tente novamente.', false);
        btn.disabled = false;
        btn.textContent = 'Inscrever';
        genCaptcha();
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
