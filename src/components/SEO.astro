---
import type { FaqItem } from '../lib/types';

interface BreadcrumbItem {
  name: string;
  item?: string;
}

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishedAt?: Date;
  updatedAt?: Date;
  author?: string;
  tags?: string[];
  slug?: string;
  faqs?: FaqItem[];
  categoryName?: string;
  categorySlug?: string;
  breadcrumbs?: BreadcrumbItem[];
}

const {
  title,
  description,
  image,
  type = 'website',
  publishedAt,
  updatedAt,
  author = 'DevLevelUp',
  tags = [],
  slug,
  faqs = [],
  categoryName,
  categorySlug,
  breadcrumbs = [],
} = Astro.props;

const siteUrl = 'https://devlevelup.com.br';
const canonicalUrl = slug ? `${siteUrl}/${slug}` : new URL(Astro.url.pathname, siteUrl).href;
const ogImage = image?.startsWith('http') ? image : image ? `${siteUrl}${image}` : `${siteUrl}/og-default.jpg`;
const fullTitle = title.includes('DevLevelUp') ? title : `${title} | DevLevelUp`;

const articleSchema = type === 'article' && publishedAt ? {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BlogPosting',
      headline: title,
      description,
      url: canonicalUrl,
      inLanguage: 'pt-BR',
      datePublished: publishedAt.toISOString(),
      dateModified: (updatedAt ?? publishedAt).toISOString(),
      image: image ? [{ '@type': 'ImageObject', url: ogImage }] : undefined,
      author: { '@type': 'Person', name: author },
      publisher: {
        '@type': 'Organization',
        name: 'DevLevelUp',
        url: siteUrl,
        logo: { '@type': 'ImageObject', url: `${siteUrl}/icon.svg`, width: 32, height: 32 },
      },
      mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
      ...(tags.length && { keywords: tags.join(', ') }),
      ...(categoryName && { articleSection: categoryName }),
    },
    ...(categorySlug ? [{
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Início', item: siteUrl },
        { '@type': 'ListItem', position: 2, name: categoryName || 'Categoria', item: `${siteUrl}/categoria/${categorySlug}` },
        { '@type': 'ListItem', position: 3, name: title, item: canonicalUrl },
      ],
    }] : []),
  ],
} : null;

const websiteSchema = type === 'website' ? {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      name: 'DevLevelUp',
      url: siteUrl,
      description: 'Guias completos de desenvolvimento de software, dicas de carreira, ferramentas de IA e tudo que um dev precisa para evoluir profissionalmente.',
      inLanguage: 'pt-BR',
      publisher: { '@type': 'Organization', name: 'DevLevelUp', url: siteUrl },
      potentialAction: {
        '@type': 'SearchAction',
        target: `${siteUrl}/?q={search_term_string}`,
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'Organization',
      name: 'DevLevelUp',
      url: siteUrl,
      logo: { '@type': 'ImageObject', url: `${siteUrl}/icon.svg`, width: 32, height: 32 },
      sameAs: [
        'https://curitibasoftware.com.br',
      ],
    },
  ],
} : null;

const breadcrumbSchema = breadcrumbs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((crumb, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: crumb.name,
    ...(crumb.item && { item: crumb.item }),
  })),
} : null;

const faqSchema = faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
} : null;
---

<!-- Primary Meta -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<link rel="canonical" href={canonicalUrl} />
<meta name="author" content={author} />
{tags.length > 0 && <meta name="keywords" content={tags.join(', ')} />}

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={fullTitle} />
<meta property="og:site_name" content="DevLevelUp" />
<meta property="og:locale" content="pt_BR" />
{type === 'article' && publishedAt && (
  <Fragment>
    <meta property="article:published_time" content={publishedAt.toISOString()} />
    <meta property="article:author" content={author} />
    {updatedAt && <meta property="article:modified_time" content={updatedAt.toISOString()} />}
    {categoryName && <meta property="article:section" content={categoryName} />}
    {tags.slice(0, 5).map(tag => (
      <meta property="article:tag" content={tag} />
    ))}
  </Fragment>
)}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={fullTitle} />

<!-- Structured Data -->
{articleSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
)}
{websiteSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
)}
{breadcrumbSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
)}
{faqSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
)}
