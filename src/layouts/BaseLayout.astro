---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import type { BlogCategory } from '../lib/types';

interface Props {
  title: string;
  description: string;
  categories?: BlogCategory[];
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#2d6a4f" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" />
  <link rel="alternate icon" type="image/png" href="/favicon.png?v=3" />
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon.png?v=3" />

  <!-- Google Fonts — async (não bloqueia renderização) -->
  <link rel="preconnect" href="https://api.curitibasoftware.com.br" crossorigin />
  <link rel="dns-prefetch" href="https://api.curitibasoftware.com.br" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;700&family=Open+Sans:wght@300;400;600;700;800&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;700&family=Open+Sans:wght@300;400;600;700;800&display=swap" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;700&family=Open+Sans:wght@300;400;600;700;800&display=swap" /></noscript>

  <!-- Font Awesome -->
  <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
  <link rel="preload" as="font" type="font/woff2" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/webfonts/fa-solid-900.woff2" crossorigin="anonymous" />
  <link rel="preload" as="font" type="font/woff2" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/webfonts/fa-brands-400.woff2" crossorigin="anonymous" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" />

  <slot name="head" />
  <script is:inline>
  (function(){
    var t = localStorage.getItem('cb-theme') ||
      (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    document.documentElement.setAttribute('data-theme', t);
  })();
  </script>
  <!-- MGID: carregado via loadAnalytics (consent-gated) -->
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>

  <!-- MGID Widget — site 1097556 / widget 2028024 -->
  <!-- Revelado apenas apos consent LGPD (script loader injetado via loadAnalytics) -->
  <div id="mgid-widget-wrapper" style="display:none">
    <div data-type="_mgwidget" data-widget-id="2028024"></div>
  </div>

  <Footer />

  <!-- Scroll to top -->
  <button id="scroll-top-btn" aria-label="Voltar ao topo" title="Voltar ao topo" style="display:none;position:fixed;bottom:1.5rem;right:1.5rem;z-index:999;width:44px;height:44px;border-radius:50%;background:var(--primary);color:#fff;border:none;cursor:pointer;box-shadow:0 4px 12px rgba(0,0,0,.25);font-size:1.1rem;align-items:center;justify-content:center;transition:opacity .2s,transform .2s">↑</button>
  <script is:inline>
    (function(){
      var btn = document.getElementById('scroll-top-btn');
      if(!btn) return;
      window.addEventListener('scroll', function(){ btn.style.display = window.scrollY > 300 ? 'flex' : 'none'; }, {passive:true});
      btn.addEventListener('click', function(){ window.scrollTo({top:0,behavior:'smooth'}); });
    })();
  </script>

  <!-- Lightbox global -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Visualizar imagem">
    <button class="lightbox-close" id="lightbox-close" aria-label="Fechar">×</button>
    <img class="lightbox-img" id="lightbox-img" src="" alt="" />
  </div>

  <script>
    // ── Lightbox ──────────────────────────────────
    const lightbox = document.getElementById('lightbox')!;
    const lbImg    = document.getElementById('lightbox-img') as HTMLImageElement;
    const lbClose  = document.getElementById('lightbox-close')!;

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const galleryImg = target.closest('[data-lightbox]') as HTMLElement | null;
      if (galleryImg) {
        e.preventDefault();
        lbImg.src = galleryImg.dataset.lightbox!;
        lbImg.alt = galleryImg.dataset.caption || '';
        lightbox.classList.add('active');
        document.body.style.overflow = 'hidden';
      }
    });

    lbClose.addEventListener('click', closeLightbox);
    lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });

    function closeLightbox() {
      lightbox.classList.remove('active');
      document.body.style.overflow = '';
      lbImg.src = '';
    }

    // ── Mobile nav ────────────────────────────────
    const toggle = document.getElementById('menu-toggle');
    const nav    = document.getElementById('site-nav');
    toggle?.addEventListener('click', () => nav?.classList.toggle('open'));

    // ── FAQ accordion ─────────────────────────────
    document.querySelectorAll('.faq-question').forEach(q => {
      q.addEventListener('click', () => {
        const item = q.closest('.faq-item');
        const wasOpen = item?.classList.contains('open');
        document.querySelectorAll('.faq-item.open').forEach(i => i.classList.remove('open'));
        if (!wasOpen) item?.classList.add('open');
      });
    });

    // ── Share copy link ───────────────────────────
    document.querySelectorAll('[data-copy-url]').forEach(btn => {
      btn.addEventListener('click', () => {
        const url = (btn as HTMLElement).dataset.copyUrl || window.location.href;
        navigator.clipboard.writeText(url).then(() => {
          btn.textContent = '✓ Copiado!';
          btn.classList.add('copied');
          setTimeout(() => {
            btn.textContent = '🔗 Copiar link';
            btn.classList.remove('copied');
          }, 2500);
        });
      });
    });

    // ── Ad click tracking ─────────────────────────
    document.querySelectorAll('[data-ad-id]').forEach(el => {
      el.addEventListener('click', () => {
        const id = (el as HTMLElement).dataset.adId;
        if (id) fetch(`https://api.curitibasoftware.com.br/api/advertisement/${id}/click`, { method: 'POST' }).catch(() => {});
      });
    });

    // ── YouTube facade (click-to-load) ───────────
    document.querySelectorAll('.yt-facade').forEach(facade => {
      facade.addEventListener('click', () => {
        const el = facade as HTMLElement;
        const src = el.dataset.src;
        const title = el.dataset.title || 'Vídeo';
        if (!src) return;
        el.style.paddingBottom = '';
        el.classList.remove('yt-facade');
        el.innerHTML = `<iframe src="${src}?autoplay=1" loading="lazy" allowfullscreen title="${title}" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" style="position:absolute;top:0;left:0;width:100%;height:100%;border:none;"></iframe>`;
      }, { once: true });
    });

    // ── Theme toggle ──────────────────────────────
    const themeBtn  = document.getElementById('theme-toggle');
    const themeIcon = document.getElementById('theme-icon');
    function setTheme(t: string) {
      document.documentElement.setAttribute('data-theme', t);
      localStorage.setItem('cb-theme', t);
      if (themeIcon) themeIcon.className = t === 'dark' ? 'fa-solid fa-sun' : 'fa-solid fa-moon';
    }
    setTheme(document.documentElement.getAttribute('data-theme') || 'light');
    themeBtn?.addEventListener('click', () => {
      setTheme(document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
    });
  </script>

  <!-- Cookie Consent Banner -->
  <div id="cookie-banner" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:9999;background:#1a1a2e;color:#e0e0e0;padding:16px 24px;box-shadow:0 -2px 12px rgba(0,0,0,.4);align-items:center;gap:16px;flex-wrap:wrap;font-size:14px;line-height:1.5">
    <span style="flex:1;min-width:220px">
      Usamos cookies para analytics e publicidade. Veja nossa
      <a href="/privacidade" style="color:#7ec8a4;text-decoration:underline">Politica de Privacidade</a>.
    </span>
    <div style="display:flex;gap:10px;flex-shrink:0">
      <button id="cookie-decline" style="padding:8px 18px;border:1px solid #7ec8a4;background:transparent;color:#7ec8a4;border-radius:6px;cursor:pointer;font-size:13px">Recusar</button>
      <button id="cookie-accept" style="padding:8px 18px;border:none;background:#2d6a4f;color:#fff;border-radius:6px;cursor:pointer;font-size:13px;font-weight:600">Aceitar todos</button>
    </div>
  </div>

  <script is:inline>
  (function() {
    var GA_ID = 'G-45FE4PES1K';
    var ADSENSE_ID = 'ca-pub-2081498160751591';
    var CONSENT_KEY = 'cookie_consent';

    function loadAnalytics() {
      var s1 = document.createElement('script');
      s1.async = true;
      s1.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
      document.head.appendChild(s1);
      window.dataLayer = window.dataLayer || [];
      function gtag(){window.dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', GA_ID);

      var s2 = document.createElement('script');
      s2.async = true;
      s2.crossOrigin = 'anonymous';
      s2.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=' + ADSENSE_ID;
      document.head.appendChild(s2);

      // MGID — loader + ativacao do widget
      var smgid = document.createElement('script');
      smgid.async = true;
      smgid.src = 'https://jsc.mgid.com/site/1097556.js';
      document.head.appendChild(smgid);
      (function(w,q){w[q]=w[q]||[];w[q].push(["_mgc.load"])})(window,"_mgq");
      var wrapper = document.getElementById('mgid-widget-wrapper');
      if (wrapper) wrapper.style.display = '';
    }

    var consent = localStorage.getItem(CONSENT_KEY);

    if (consent === 'accepted') {
      loadAnalytics();
      return;
    }

    if (consent === 'declined') {
      return;
    }

    // Sem resposta — exibir banner
    var banner = document.getElementById('cookie-banner');
    if (banner) banner.style.display = 'flex';

    document.getElementById('cookie-accept').addEventListener('click', function() {
      localStorage.setItem(CONSENT_KEY, 'accepted');
      if (banner) banner.style.display = 'none';
      loadAnalytics();
    });

    document.getElementById('cookie-decline').addEventListener('click', function() {
      localStorage.setItem(CONSENT_KEY, 'declined');
      if (banner) banner.style.display = 'none';
    });
  })();
  </script>
  <!-- MGID Deslize para Cima -->
  <div data-type="_mgwidget" data-widget-id="2037406"></div>
  <script>(function(w,q){w[q]=w[q]||[];w[q].push(["_mgc.load"])})(window,"_mgq");</script>
</body>
</html>
