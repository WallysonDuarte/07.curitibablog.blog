---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import PostCard from '../components/PostCard.astro';
import { fetchAllPosts, fetchCategories } from '../lib/api';

const PAGE_SIZE = 12;
const [allPosts, categories] = await Promise.all([fetchAllPosts(), fetchCategories()]);
const sorted = allPosts.sort((a, b) =>
  new Date(b.publishedAt || b.createdAt).getTime() - new Date(a.publishedAt || a.createdAt).getTime()
);
const initialPosts = sorted.slice(0, PAGE_SIZE);

const tagCountMap: Record<string, number> = {};
allPosts.forEach(p => (p.tags || []).forEach(t => { tagCountMap[t] = (tagCountMap[t] || 0) + 1; }));
const allTags = Object.entries(tagCountMap).sort((a, b) => b[1] - a[1]).map(([tag, count]) => ({ tag, count }));

const withCovers = allPosts.filter(p => p.coverImageUrl);
const carouselItems = [...withCovers].sort(() => Math.random() - 0.5).slice(0, 10);
---

<BaseLayout
  title="CuritibaBlog — Tecnologia, IA e Desenvolvimento de Software"
  description="Artigos sobre inteligência artificial, desenvolvimento de software e ferramentas tech. Guias completos, análises e dicas práticas para profissionais e entusiastas de TI."
>
  <SEO
    slot="head"
    title="CuritibaBlog — Tecnologia, IA e Desenvolvimento de Software"
    description="Artigos sobre inteligência artificial, desenvolvimento de software e ferramentas tech. Guias completos, análises e dicas práticas para profissionais e entusiastas de TI."
    type="website"
  />

  <!-- Particle Hero -->
  <section class="page-hero particle-hero" id="hero" style="position:relative;background:#0d1b2a;overflow:hidden;">
    <canvas id="hero-canvas" style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;"></canvas>
    <div class="container" style="position:relative;z-index:1;">
      <h1>Tecnologia que Funciona</h1>
      <p>Artigos, guias e dicas sobre IA, desenvolvimento e as melhores ferramentas tech</p>
      <div class="search-bar" id="search-bar">
        <input type="search" id="search-input" placeholder="Buscar artigos de tecnologia..." aria-label="Buscar artigos" autocomplete="off" />
        <button type="button" aria-label="Buscar"><i class="fa-solid fa-search"></i></button>
      </div>
    </div>
  </section>

  <!-- Category filter pills -->
  {categories.length > 0 && (
    <section style="padding:1.5rem 0 .5rem;background:var(--bg-light);border-bottom:1px solid var(--border);">
      <div class="container">
        <div class="filter-bar">
          <a href="/" class="filter-pill active" data-cat="">Todos</a>
          {categories.map(cat => (
            <a href={`/categoria/${cat.slug}`} class="filter-pill" data-cat={cat.slug}>
              {cat.name}
              {cat.postCount > 0 && <span style="opacity:.6;font-size:.75em;margin-left:.3rem">({cat.postCount})</span>}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Cover carousel -->
  {carouselItems.length >= 3 && (
    <section style="padding:1rem 0;background:var(--bg);border-bottom:1px solid var(--border);">
      <div class="container">
        <div id="cover-carousel" style="display:flex;gap:0.75rem;overflow-x:auto;scroll-behavior:smooth;scrollbar-width:none;padding-bottom:0.25rem;">
          {carouselItems.map(post => (
            <a href={`/${post.slug}`} style="flex:0 0 auto;width:200px;border-radius:10px;overflow:hidden;position:relative;display:block;text-decoration:none;box-shadow:0 2px 8px rgba(0,0,0,.15);background:#111;">
              <img src={post.coverImageUrl} alt={post.title} loading="lazy" style="width:100%;height:120px;object-fit:cover;display:block;" />
              <div style="position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(0,0,0,.75));padding:.5rem .6rem .4rem;font-size:.7rem;color:#fff;line-height:1.3;font-weight:600;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">{post.title}</div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Posts grid + Tags sidebar -->
  <section class="posts-section">
    <div class="container">
      {initialPosts.length === 0 ? (
        <div class="empty-state">
          <i class="fa-solid fa-newspaper"></i>
          <p>Nenhum artigo disponível no momento.</p>
        </div>
      ) : (
        <div style="display:flex;gap:1.5rem;align-items:flex-start;">

          <!-- Sidebar de Tags -->
          {allTags.length > 0 && (
            <aside id="tags-sidebar" style="width:190px;flex-shrink:0;">
              <div style="position:sticky;top:1rem;background:var(--bg-light);border:1px solid var(--border);border-radius:10px;padding:1rem;max-height:calc(100vh - 2rem);overflow-y:auto;">
                <p style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text-muted);margin:0 0 .75rem;">Filtrar por tag</p>
                <a href="#" class="tag-sidebar-item active" data-tag="" style="display:block;padding:.3rem .5rem;border-radius:6px;font-size:.8rem;color:var(--text);text-decoration:none;margin-bottom:.2rem;transition:background .15s;">
                  # todos <span style="opacity:.5;font-size:.72em">({sorted.length})</span>
                </a>
                {allTags.map(({ tag, count }) => (
                  <a href="#" class="tag-sidebar-item" data-tag={tag}
                    style="display:block;padding:.3rem .5rem;border-radius:6px;font-size:.8rem;color:var(--text);text-decoration:none;margin-bottom:.2rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;transition:background .15s;"
                    title={tag}>
                    #{tag} <span style="opacity:.5;font-size:.72em">({count})</span>
                  </a>
                ))}
              </div>
            </aside>
          )}

          <!-- Posts + Paginação -->
          <div style="flex:1;min-width:0;">
            <div class="section-title"><h2>Artigos Recentes</h2></div>
            <div class="posts-grid" id="posts-grid" data-site="">
              {initialPosts.map(post => (
                <PostCard
                  title={post.title}
                  summary={post.summary}
                  slug={post.slug}
                  publishedAt={post.publishedAt}
                  createdAt={post.createdAt}
                  category={post.category}
                  categories={post.categories}
                  tags={post.tags}
                  coverImageUrl={post.coverImageUrl}
                  views={post.views}
                />
              ))}
            </div>
            <div id="load-more-sentinel" style="height:1px;margin-top:2rem;"></div>
            <div id="load-more-spinner" style="display:none;text-align:center;padding:2rem 0;color:var(--text-muted);font-size:.9rem;">
              <i class="fa-solid fa-spinner fa-spin" style="margin-right:.5rem;"></i>Carregando mais artigos...
            </div>
            <div id="no-results" style="display:none" class="empty-state">
              <i class="fa-solid fa-search"></i>
              <p>Nenhum artigo encontrado.</p>
            </div>
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  // ── Utilitários ──────────────────────────────────────────
  function toSlug(n: string): string {
    return n.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g,'')
      .replace(/[^a-z0-9\s-]/g,'').trim().replace(/\s+/g,'-').replace(/-+/g,'-');
  }
  function fmtDate(d: string): string {
    try { return new Date(d).toLocaleDateString('pt-BR',{day:'2-digit',month:'long',year:'numeric'}); } catch { return ''; }
  }
  function esc(s: unknown): string {
    return String(s??'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // ── Renderizar card idêntico ao PostCard.astro ────────────
  function renderCard(p: Record<string,unknown>): string {
    const cat  = esc((p.categories as string[])?.[0] ?? p.category ?? '');
    const date = fmtDate((p.publishedAt || p.createdAt) as string);
    const tags: string[] = Array.isArray(p.tags) ? p.tags as string[] : [];
    const views = Number(p.views ?? 0);
    const img = p.coverImageUrl
      ? `<div class="post-card-image"><img src="${esc(p.coverImageUrl)}" alt="${esc(p.title)}" loading="lazy" decoding="async">${cat?`<span class="card-category">${cat}</span>`:''}</div>`
      : `<div class="post-card-image-placeholder"><span>📍</span>${cat?`<span class="card-category">${cat}</span>`:''}</div>`;
    const tagLinks = tags.slice(0,3).map(t=>`<a href="/tag/${toSlug(t)}" class="card-tag" onclick="event.stopPropagation()">#${esc(t)}</a>`).join('');
    return `<article class="post-card" data-tags="${esc(tags.join(','))}">
      <a href="/${esc(p.slug)}" tabindex="-1" aria-hidden="true">${img}</a>
      <div class="post-card-body">
        <h2><a href="/${esc(p.slug)}">${esc(p.title)}</a></h2>
        <p>${esc(p.summary)}</p>
        <div class="card-meta"><span>📅 ${date}</span>${views>0?`<span>👁 ${views.toLocaleString('pt-BR')}</span>`:''}</div>
        ${tags.length?`<div class="card-tags">${tagLinks}</div>`:''}
      </div>
    </article>`;
  }

  // ── Estado da paginação ──────────────────────────────────
  const API       = 'https://api.curitibasoftware.com.br';
  const SITE      = (document.getElementById('posts-grid') as HTMLElement)?.dataset.site ?? '';
  const PAGE_SIZE = 12;
  let page      = 1;
  let loading   = false;
  let hasMore   = true;
  let activeTag = '';

  const grid    = document.getElementById('posts-grid')       as HTMLElement;
  const noRes   = document.getElementById('no-results')       as HTMLElement;
  const spinner = document.getElementById('load-more-spinner') as HTMLElement;
  const input   = document.getElementById('search-input')     as HTMLInputElement;

  async function loadMore(): Promise<void> {
    if (loading || !hasMore || !grid) return;
    loading = true;
    if (spinner) spinner.style.display = 'block';
    try {
      const url = new URL(`${API}/api/blog/posts`);
      url.searchParams.set('page', String(page + 1));
      url.searchParams.set('pageSize', String(PAGE_SIZE));
      if (SITE) url.searchParams.set('site', SITE);
      if (activeTag) url.searchParams.set('tag', activeTag);
      const res  = await fetch(url.toString());
      const json = await res.json();
      const data = json?.data;
      if (data?.items?.length) {
        page++;
        grid.insertAdjacentHTML('beforeend', (data.items as Record<string,unknown>[]).map(renderCard).join(''));
        const loaded = grid.querySelectorAll('.post-card').length;
        if (loaded >= Number(data.totalCount ?? 0)) hasMore = false;
      } else {
        hasMore = false;
      }
    } catch { hasMore = false; }
    loading = false;
    if (spinner) spinner.style.display = hasMore ? '' : 'none';
  }

  async function resetAndLoad(): Promise<void> {
    page    = 0;
    hasMore = true;
    loading = false;
    if (grid) { grid.innerHTML = ''; grid.style.display = ''; }
    if (noRes) noRes.style.display = 'none';
    await loadMore();
  }

  // IntersectionObserver — dispara ao aproximar do fim
  const sentinel = document.getElementById('load-more-sentinel');
  if (sentinel) {
    new IntersectionObserver(
      entries => { if (entries[0].isIntersecting) loadMore(); },
      { rootMargin: '600px' }
    ).observe(sentinel);
  }

  // ── Busca client-side nos cards carregados ───────────────
  if (input) {
    input.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();
      let visible = 0;
      grid?.querySelectorAll<HTMLElement>('.post-card').forEach(card => {
        const show = !q || Boolean(card.textContent?.toLowerCase().includes(q));
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (noRes) noRes.style.display = visible === 0 ? 'block' : 'none';
      if (grid) grid.style.display = visible === 0 ? 'none' : '';
    });
  }

  // ── Tag sidebar → reset + reload via API ────────────────
  document.querySelectorAll<HTMLElement>('.tag-sidebar-item').forEach(btn => {
    btn.addEventListener('click', async e => {
      e.preventDefault();
      activeTag = btn.dataset.tag ?? '';
      document.querySelectorAll<HTMLElement>('.tag-sidebar-item').forEach(b => {
        b.classList.remove('active');
        b.style.background = '';
        b.style.color      = '';
        b.style.fontWeight = '';
      });
      btn.classList.add('active');
      btn.style.background = 'var(--primary,#2d6a4f)';
      btn.style.color      = '#fff';
      btn.style.fontWeight = '600';
      if (input) input.value = '';
      await resetAndLoad();
    });
  });

  // ── Particle hero ────────────────────────────────────────
  (function () {
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx  = canvas.getContext('2d');
    if (!ctx)  return;
    const hero = document.getElementById('hero') as HTMLElement;
    const mouse = { x: -9999, y: -9999 };
    type Particle = { x: number; y: number; vx: number; vy: number; r: number };
    let particles: Particle[] = [];
    function resize() {
      canvas.width  = hero.offsetWidth;
      canvas.height = hero.offsetHeight;
      const count = Math.min(60, Math.floor(canvas.width * canvas.height / 15000));
      particles = Array.from({ length: count }, () => ({
        x: Math.random()*canvas.width, y: Math.random()*canvas.height,
        vx: (Math.random()-0.5)*0.8,   vy: (Math.random()-0.5)*0.8,
        r:  1.5+Math.random()*3,
      }));
    }
    function draw() {
      ctx.clearRect(0,0,canvas.width,canvas.height);
      for (let i=0;i<particles.length;i++) {
        const p=particles[i];
        const dx=p.x-mouse.x, dy=p.y-mouse.y, dist=Math.sqrt(dx*dx+dy*dy);
        if (dist<100&&dist>0){const f=(100-dist)/100;p.vx+=(dx/dist)*f*1.5;p.vy+=(dy/dist)*f*1.5;}
        const spd=Math.sqrt(p.vx*p.vx+p.vy*p.vy);
        if(spd>3){p.vx=(p.vx/spd)*3;p.vy=(p.vy/spd)*3;}
        p.x+=p.vx;p.y+=p.vy;
        if(p.x<0){p.x=0;p.vx=Math.abs(p.vx);}if(p.x>canvas.width){p.x=canvas.width;p.vx=-Math.abs(p.vx);}
        if(p.y<0){p.y=0;p.vy=Math.abs(p.vy);}if(p.y>canvas.height){p.y=canvas.height;p.vy=-Math.abs(p.vy);}
        ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fillStyle='rgba(255,255,255,0.7)';ctx.fill();
        for(let j=i+1;j<particles.length;j++){
          const q=particles[j],cx=p.x-q.x,cy=p.y-q.y,cd=Math.sqrt(cx*cx+cy*cy);
          if(cd<120){ctx.beginPath();ctx.moveTo(p.x,p.y);ctx.lineTo(q.x,q.y);ctx.strokeStyle=`rgba(255,255,255,${0.3*(1-cd/120)})`;ctx.lineWidth=0.5;ctx.stroke();}
        }
      }
      requestAnimationFrame(draw);
    }
    hero.addEventListener('mousemove',(e:MouseEvent)=>{const r=canvas.getBoundingClientRect();mouse.x=e.clientX-r.left;mouse.y=e.clientY-r.top;});
    hero.addEventListener('mouseleave',()=>{mouse.x=-9999;mouse.y=-9999;});
    window.addEventListener('resize',resize);resize();draw();
  })();

  // ── Carousel auto-scroll ─────────────────────────────────
  (function () {
    const c=document.getElementById('cover-carousel') as HTMLElement|null;
    if(!c) return;
    let dir=1;
    setInterval(()=>{
      c.scrollLeft+=dir*1.5;
      if(c.scrollLeft+c.clientWidth>=c.scrollWidth-5)dir=-1;
      if(c.scrollLeft<=5)dir=1;
    },30);
  })();
</script>
