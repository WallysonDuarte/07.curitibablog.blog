---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import PostCard from '../components/PostCard.astro';
import { fetchAllPosts, fetchCategories } from '../lib/api';

const [allPosts, categories] = await Promise.all([fetchAllPosts(), fetchCategories()]);

const API_BASE = 'https://api.curitibasoftware.com.br';
// Carrossel: posts em destaque ordenados por sequence
const featuredPosts = allPosts.filter(p => p.isFeatured)
  .sort((a, b) => (a.sequence ?? 9999) - (b.sequence ?? 9999));
const fallbackPosts = allPosts.filter(p => !p.isFeatured)
  .sort((a, b) => new Date(b.publishedAt || b.createdAt).getTime() - new Date(a.publishedAt || a.createdAt).getTime());
const carouselSlides = featuredPosts.length >= 3
  ? featuredPosts.slice(0, 8)
  : [...featuredPosts, ...fallbackPosts].slice(0, 8);

// Blocos por categoria
function getCatKey(p: typeof allPosts[0]): string[] {
  return p.categories?.length ? p.categories : (p.category ? [p.category] : []);
}
const categoryBlocks = categories.map(cat => {
  const catPosts = allPosts
    .filter(p => {
      const keys = getCatKey(p);
      return keys.some(k => k === cat.slug || k === cat.name || k === cat.id);
    })
    .sort((a, b) => {
      const sa = a.sequence ?? 9999;
      const sb = b.sequence ?? 9999;
      if (sa !== sb) return sa - sb;
      return new Date(b.publishedAt || b.createdAt).getTime() - new Date(a.publishedAt || a.createdAt).getTime();
    });
  const catTags = [...new Set(catPosts.flatMap(p => p.tags || []))]
    .sort((a, b) => a.localeCompare(b, 'pt-BR', { sensitivity: 'base' }));
  return { category: cat, posts: catPosts.slice(0, 6), totalPosts: catPosts.length, tags: catTags };
}).filter(b => b.posts.length > 0);
---

<BaseLayout
  title="CuritibaBlog — Tecnologia, IA e Desenvolvimento de Software"
  description="Artigos sobre inteligência artificial, desenvolvimento de software e ferramentas tech. Guias completos, análises e dicas práticas para profissionais e entusiastas de TI."
>
  <SEO
    slot="head"
    title="CuritibaBlog — Tecnologia, IA e Desenvolvimento de Software"
    description="Artigos sobre inteligência artificial, desenvolvimento de software e ferramentas tech. Guias completos, análises e dicas práticas para profissionais e entusiastas de TI."
    type="website"
  />

  <!-- Particle Hero -->
  <section class="page-hero particle-hero" id="hero" style="position:relative;background:#0d1b2a;overflow:hidden;">
    <canvas id="hero-canvas" style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;"></canvas>
    <div class="container" style="position:relative;z-index:1;">
      <h1>Tecnologia que Funciona</h1>
      <p>Artigos, guias e dicas sobre IA, desenvolvimento e as melhores ferramentas tech</p>
      <div class="search-bar" id="search-bar">
        <input type="search" id="search-input" placeholder="Buscar artigos de tecnologia..." aria-label="Buscar artigos" autocomplete="off" />
        <button type="button" aria-label="Buscar"><i class="fa-solid fa-search"></i></button>
      </div>
    </div>
  </section>

  <!-- Category filter pills -->
  {categories.length > 0 && (
    <section style="padding:1.5rem 0 .5rem;background:var(--bg-light);border-bottom:1px solid var(--border);">
      <div class="container">
        <!-- Desktop: pills diretas -->
        <div class="filter-bar">
          <a href="/" class="filter-pill active" data-cat="">Todos</a>
          {categories.map(cat => (
            <a href={`/categoria/${cat.slug}`} class="filter-pill" data-cat={cat.slug}>
              {cat.name}
              {cat.postCount > 0 && <span style="opacity:.6;font-size:.75em;margin-left:.3rem">({cat.postCount})</span>}
            </a>
          ))}
        </div>
        <!-- Mobile: botao toggle + panel colapsavel -->
        <button id="filter-mobile-toggle" class="filter-mobile-toggle" aria-expanded="false" aria-controls="filter-mobile-panel">
          <i class="fa-solid fa-filter"></i>
          Filtrar por categoria
          <span class="toggle-arrow">&#9660;</span>
        </button>
        <div id="filter-mobile-panel" class="filter-mobile-panel" role="region" aria-labelledby="filter-mobile-toggle">
          <a href="/" class="filter-pill active" data-cat="">Todos</a>
          {categories.map(cat => (
            <a href={`/categoria/${cat.slug}`} class="filter-pill" data-cat={cat.slug}>
              {cat.name}
              {cat.postCount > 0 && <span style="opacity:.6;font-size:.75em;margin-left:.3rem">({cat.postCount})</span>}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Carrossel principal (grande) -->
  {carouselSlides.length > 0 && (
    <section class="main-carousel-section">
      <div class="main-carousel" id="main-carousel">
        <div class="carousel-track" id="carousel-track">
          {carouselSlides.map((post, i) => (
            <div class="carousel-slide" data-index={i} aria-hidden={i !== 0 ? 'true' : undefined} inert={i !== 0 ? true : undefined}>
              <picture>
                <source type="image/webp" srcset={`${API_BASE}/api/blog/cover/${post.slug}?format=webp&w=1200`} />
                <img src={`${API_BASE}/api/blog/cover/${post.slug}?w=1200`} alt={post.title} width="1200" height="630" loading={i === 0 ? 'eager' : 'lazy'} fetchpriority={i === 0 ? 'high' : undefined} class="carousel-img" />
              </picture>
              <div class="carousel-overlay">
                <div class="carousel-content">
                  {(post.categories?.[0] || post.category) && (
                    <span class="carousel-cat">{post.categories?.[0] || post.category}</span>
                  )}
                  <h2 class="carousel-title">{post.title}</h2>
                  <p class="carousel-summary">{post.summary}</p>
                  <a href={`/${post.slug}`} class="carousel-cta">Ler artigo <i class="fa-solid fa-arrow-right"></i></a>
                </div>
              </div>
            </div>
          ))}
        </div>
        <button class="carousel-btn carousel-prev" id="carousel-prev" aria-label="Anterior">&#8249;</button>
        <button class="carousel-btn carousel-next" id="carousel-next" aria-label="Proximo">&#8250;</button>
        <div class="carousel-dots" id="carousel-dots">
          {carouselSlides.map((_, i) => (
            <button class={`carousel-dot${i === 0 ? ' active' : ''}`} data-index={i} aria-label={`Slide ${i + 1}`}></button>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Blocos por Categoria -->
  <div id="no-results" style="display:none;text-align:center;padding:3rem 1rem;color:var(--text-muted);">
    <i class="fa-solid fa-search" style="font-size:2rem;margin-bottom:.75rem;display:block;"></i>
    <p>Nenhum artigo encontrado.</p>
  </div>

  {categoryBlocks.map(({ category, posts, totalPosts, tags }) => (
    <section class="category-block" data-cat-slug={category.slug} id={`cat-${category.slug}`}>
      <div class="container">
        <div class="cat-block-header">
          <h2 class="cat-block-title">{category.name}</h2>
          {totalPosts > 6 && (
            <a href={`/categoria/${category.slug}`} class="cat-view-all">
              Ver todos ({totalPosts}) <i class="fa-solid fa-arrow-right"></i>
            </a>
          )}
        </div>

        {tags.length > 0 && (
          <div class="cat-tag-pills" data-cat={category.slug}>
            <button class="cat-tag-pill active" data-tag="">Todos</button>
            {tags.slice(0, 18).map(tag => (
              <button class="cat-tag-pill" data-tag={tag}>#{tag}</button>
            ))}
          </div>
        )}

        <div class="category-posts-grid" data-cat={category.slug}>
          {posts.map((post, i) => (
            <div class="post-wrap" data-tags={(post.tags || []).join(',').toLowerCase()}>
              <PostCard
                title={post.title}
                summary={post.summary}
                slug={post.slug}
                publishedAt={post.publishedAt}
                createdAt={post.createdAt}
                category={post.category}
                categories={post.categories}
                tags={post.tags}
                coverImageUrl={post.coverImageUrl} coverImageKey={post.coverImageKey}
                views={post.views}
                ratings={post.ratings}
              />
            </div>
          ))}
        </div>

        {totalPosts > 6 && (
          <div class="cat-block-footer">
            <a href={`/categoria/${category.slug}`} class="cat-view-all-btn">
              Ver todos os {totalPosts} artigos de {category.name} <i class="fa-solid fa-arrow-right"></i>
            </a>
          </div>
        )}
      </div>
    </section>
  ))}
</BaseLayout>

<script>
  // ── Carrossel principal ───────────────────────────────────
  (function () {
    const track  = document.getElementById('carousel-track') as HTMLElement | null;
    const dots   = document.querySelectorAll<HTMLElement>('.carousel-dot');
    const slides = document.querySelectorAll<HTMLElement>('.carousel-slide');
    if (!track || slides.length === 0) return;

    let current = 0;
    let timer: ReturnType<typeof setInterval> | undefined;
    let paused = false;

    function goTo(idx: number): void {
      current = (idx + slides.length) % slides.length;
      track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => d.classList.toggle('active', i === current));
      slides.forEach((s, i) => {
        if (i !== current) {
          s.setAttribute('aria-hidden', 'true');
          s.setAttribute('inert', '');
        } else {
          s.removeAttribute('aria-hidden');
          s.removeAttribute('inert');
        }
      });
    }

    function next(): void { goTo(current + 1); }
    function prev(): void { goTo(current - 1); }

    function startTimer(): void {
      clearInterval(timer);
      if (!paused) timer = setInterval(next, 10000);
    }

    document.getElementById('carousel-next')?.addEventListener('click', () => { next(); startTimer(); });
    document.getElementById('carousel-prev')?.addEventListener('click', () => { prev(); startTimer(); });
    dots.forEach(dot => dot.addEventListener('click', () => { goTo(Number(dot.dataset.index)); startTimer(); }));

    const section = document.querySelector('.main-carousel-section');
    section?.addEventListener('mouseenter', () => { paused = true; clearInterval(timer); });
    section?.addEventListener('mouseleave', () => { paused = false; startTimer(); });

    startTimer();
  })();

  // ── Tag pills por bloco de categoria ─────────────────────
  document.querySelectorAll<HTMLElement>('.cat-tag-pills').forEach(pillGroup => {
    const catSlug = pillGroup.dataset.cat ?? '';
    const grid = document.querySelector<HTMLElement>(`.category-posts-grid[data-cat="${catSlug}"]`);
    if (!grid) return;

    pillGroup.querySelectorAll<HTMLElement>('.cat-tag-pill').forEach(pill => {
      pill.addEventListener('click', () => {
        pillGroup.querySelectorAll('.cat-tag-pill').forEach(p => p.classList.remove('active'));
        pill.classList.add('active');
        const tag = pill.dataset.tag ?? '';
        grid.querySelectorAll<HTMLElement>('.post-wrap').forEach(wrap => {
          if (!tag) {
            wrap.style.display = '';
          } else {
            const tags = (wrap.dataset.tags ?? '').toLowerCase().split(',').map(t => t.trim());
            wrap.style.display = tags.includes(tag.toLowerCase()) ? '' : 'none';
          }
        });
      });
    });
  });

  // ── Busca fuzzy global (filtra por blocos) ────────────────
  function norm(s: string): string {
    return s.normalize('NFD').replace(/[̀-ͯ]/g, '').toLowerCase();
  }

  function lev(a: string, b: string): number {
    if (a === b) return 0;
    if (a.length === 0) return b.length;
    if (b.length === 0) return a.length;
    const row: number[] = Array.from({ length: b.length + 1 }, (_, i) => i);
    for (let i = 1; i <= a.length; i++) {
      let prev = i;
      for (let j = 1; j <= b.length; j++) {
        const val = a[i - 1] === b[j - 1] ? row[j - 1] : 1 + Math.min(row[j - 1], row[j], prev);
        row[j - 1] = prev;
        prev = val;
      }
      row[b.length] = prev;
    }
    return row[b.length];
  }

  function wordMatchesText(word: string, text: string): boolean {
    const maxDist = word.length <= 3 ? 0 : word.length <= 5 ? 1 : 2;
    if (text.includes(word)) return true;
    const words = text.split(/\s+/);
    for (const w of words) {
      if (Math.abs(w.length - word.length) <= maxDist && lev(word, w) <= maxDist) return true;
    }
    return false;
  }

  function fuzzyMatch(query: string, text: string): boolean {
    const nq = norm(query);
    const nt = norm(text);
    const parts = nq.split(/\s+/).filter(Boolean);
    return parts.every(p => wordMatchesText(p, nt));
  }

  const noRes = document.getElementById('no-results') as HTMLElement;
  const input = document.getElementById('search-input') as HTMLInputElement;
  let searchTimer: ReturnType<typeof setTimeout> | undefined;

  if (input) {
    input.addEventListener('input', () => {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => {
        const q = input.value.trim();
        let totalVisible = 0;

        document.querySelectorAll<HTMLElement>('.category-block').forEach(block => {
          let blockVisible = 0;
          block.querySelectorAll<HTMLElement>('.post-wrap').forEach(wrap => {
            const show = !q || fuzzyMatch(q, wrap.textContent ?? '');
            wrap.style.display = show ? '' : 'none';
            if (show) blockVisible++;
          });
          block.style.display = blockVisible === 0 && q ? 'none' : '';
          totalVisible += blockVisible;
        });

        if (noRes) noRes.style.display = totalVisible === 0 && q ? 'block' : 'none';
      }, 150);
    });
  }

  // ── Particle hero ────────────────────────────────────────
  (function () {
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx  = canvas.getContext('2d');
    if (!ctx)  return;
    const hero = document.getElementById('hero') as HTMLElement;
    const mouse = { x: -9999, y: -9999 };
    type Particle = { x: number; y: number; vx: number; vy: number; r: number };
    let particles: Particle[] = [];
    function resize() {
      canvas.width  = hero.offsetWidth;
      canvas.height = hero.offsetHeight;
      const count = Math.min(60, Math.floor(canvas.width * canvas.height / 15000));
      particles = Array.from({ length: count }, () => ({
        x: Math.random()*canvas.width, y: Math.random()*canvas.height,
        vx: (Math.random()-0.5)*0.8,   vy: (Math.random()-0.5)*0.8,
        r:  1.5+Math.random()*3,
      }));
    }
    function draw() {
      ctx.clearRect(0,0,canvas.width,canvas.height);
      for (let i=0;i<particles.length;i++) {
        const p=particles[i];
        const dx=p.x-mouse.x, dy=p.y-mouse.y, dist=Math.sqrt(dx*dx+dy*dy);
        if (dist<100&&dist>0){const f=(100-dist)/100;p.vx+=(dx/dist)*f*1.5;p.vy+=(dy/dist)*f*1.5;}
        const spd=Math.sqrt(p.vx*p.vx+p.vy*p.vy);
        if(spd>3){p.vx=(p.vx/spd)*3;p.vy=(p.vy/spd)*3;}
        p.x+=p.vx;p.y+=p.vy;
        if(p.x<0){p.x=0;p.vx=Math.abs(p.vx);}if(p.x>canvas.width){p.x=canvas.width;p.vx=-Math.abs(p.vx);}
        if(p.y<0){p.y=0;p.vy=Math.abs(p.vy);}if(p.y>canvas.height){p.y=canvas.height;p.vy=-Math.abs(p.vy);}
        ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fillStyle='rgba(255,255,255,0.7)';ctx.fill();
        for(let j=i+1;j<particles.length;j++){
          const q=particles[j],cx=p.x-q.x,cy=p.y-q.y,cd=Math.sqrt(cx*cx+cy*cy);
          if(cd<120){ctx.beginPath();ctx.moveTo(p.x,p.y);ctx.lineTo(q.x,q.y);ctx.strokeStyle=`rgba(255,255,255,${0.3*(1-cd/120)})`;ctx.lineWidth=0.5;ctx.stroke();}
        }
      }
      requestAnimationFrame(draw);
    }
    hero.addEventListener('mousemove',(e:MouseEvent)=>{const r=canvas.getBoundingClientRect();mouse.x=e.clientX-r.left;mouse.y=e.clientY-r.top;});
    hero.addEventListener('mouseleave',()=>{mouse.x=-9999;mouse.y=-9999;});
    window.addEventListener('resize',resize);resize();draw();
  })();

  // ── Carousel auto-scroll ─────────────────────────────────
  (function () {
    const c=document.getElementById('cover-carousel') as HTMLElement|null;
    if(!c) return;
    let dir=1;
    setInterval(()=>{
      const sl=c.scrollLeft;const sw=c.scrollWidth;const cw=c.clientWidth;
      c.scrollLeft=sl+dir*1.5;if(sl+cw>=sw-5)dir=-1;
      if(sl<=5)dir=1;
    },30);
  })();

  // ── Mobile filter toggle ─────────────────────────────────
  (function () {
    const btn   = document.getElementById('filter-mobile-toggle') as HTMLButtonElement | null;
    const panel = document.getElementById('filter-mobile-panel') as HTMLElement | null;
    if (!btn || !panel) return;
    btn.addEventListener('click', () => {
      const open = panel.classList.toggle('open');
      btn.classList.toggle('open', open);
      btn.setAttribute('aria-expanded', String(open));
    });
  })();
</script>
