---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
---

<BaseLayout title="Página não encontrada — DevLevelUp" description="A página que você está procurando não foi encontrada.">
  <SEO
    slot="head"
    title="Página não encontrada"
    description="A página que você está procurando não foi encontrada."
  />
  <div style="text-align:center;padding:4rem 1rem;min-height:50vh;display:flex;flex-direction:column;align-items:center;justify-content:center;">
    <h1 style="font-size:5rem;margin:0;color:var(--primary,#2d6a4f);">404</h1>
    <p style="font-size:1.3rem;margin:.5rem 0 2rem;">Página não encontrada</p>
    <a href="/" style="background:var(--primary,#2d6a4f);color:#fff;padding:.75rem 2rem;border-radius:.5rem;text-decoration:none;font-weight:600;">
      Voltar para o início
    </a>
  </div>
</BaseLayout>
