---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import PostCard from '../components/PostCard.astro';
import PostRatings from '../components/PostRatings.astro';
import AuthorCard from '../components/AuthorCard.astro';
import RichBlock from '../components/RichBlock.astro';
import AdBanner from '../components/AdBanner.astro';
import LikeButton from '../components/LikeButton.astro';
import CommentSection from '../components/CommentSection.astro';
import WhatsAppPopup from '../components/WhatsAppPopup.astro';
import { fetchAllPosts, fetchCategories, fetchAds, fetchRelatedPosts } from '../lib/api';
import { formatDate, buildSections, getPostCategories, toSlug } from '../lib/utils';

export async function getStaticPaths() {
  const posts = await fetchAllPosts();
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;

const [categories, inlineAds, sidebarAds, faqSideAds, relatedPosts] = await Promise.all([
  fetchCategories(),
  fetchAds('inline'),
  fetchAds('sidebar'),
  fetchAds('faq-side'),
  fetchRelatedPosts(post.id),
]);

const postCats = getPostCategories(post);
const breadcrumbCats = postCats.map(s => {
  const found = categories.find(c => c.slug === s || c.name === s);
  return { name: found?.name ?? s, slug: found?.slug ?? toSlug(s) };
});
const primaryCat = breadcrumbCats[0];

// Build sections with blocks
const blocks = post.blocks ?? [];
const sections = buildSections(post.content || '', blocks);

// Adjacent posts in same category (sorted by date, including current)
const sortedInCat = allPosts
  .filter(p => getPostCategories(p).some(c => postCats.includes(c)))
  .sort((a, b) => new Date(b.publishedAt || b.createdAt).getTime() - new Date(a.publishedAt || a.createdAt).getTime());

const currentIdx = sortedInCat.findIndex(p => p.id === post.id);
const prevPost = currentIdx > 0 ? sortedInCat[currentIdx - 1] : null;
const nextPost = currentIdx >= 0 && currentIdx < sortedInCat.length - 1 ? sortedInCat[currentIdx + 1] : null;

// Suggested posts (related or most recent)
const suggested = relatedPosts.length >= 3
  ? relatedPosts.slice(0, 6)
  : allPosts.filter(p => p.id !== post.id).sort((a, b) => b.views - a.views).slice(0, 6);

const siteUrl = 'https://curitibablog.com.br';
const shareUrl = `${siteUrl}/${post.slug}`;
const publishDate = post.publishedAt || post.createdAt;
const metaTitle = post.metaTitle || post.title;
const metaDesc  = post.metaDescription || post.summary;

const spotifyEmbedUrl = post.podcastUrl ? (() => {
  try { return `https://open.spotify.com/embed${new URL(post.podcastUrl).pathname}`; }
  catch { return null; }
})() : null;

const API_BASE = 'https://api.curitibasoftware.com.br';
const postCoverSrc = `${API_BASE}/api/blog/cover/${post.slug}`;
const postCoverWebP = `${postCoverSrc}?format=webp&w=1200`;

// Pick one inline ad to rotate per section
const inlineAd = inlineAds[0] ?? null;
const sidebarAd = sidebarAds[0] ?? null;
const faqSideAd = faqSideAds[0] ?? null;
---

<BaseLayout title={`${metaTitle} | CuritibaBlog`} description={metaDesc}>
  <SEO
    slot="head"
    title={metaTitle}
    description={metaDesc}
    image={postCoverSrc ?? undefined}
    type="article"
    publishedAt={new Date(publishDate)}
    updatedAt={new Date(post.updatedAt)}
    author={post.authorName}
    tags={post.tags}
    slug={post.slug}
    faqs={post.faqs}
    categoryName={primaryCat?.name}
    categorySlug={primaryCat?.slug}
  />

  <div class="post-layout">
    <!-- ── MAIN ARTICLE ── -->
    <article>
      <!-- Cover image + side card (desktop) -->
      <div class="post-cover-row">
        <div class="post-cover-hero">
          <picture>
            <source type="image/webp" srcset={postCoverWebP} />
            <img src={postCoverSrc} alt={post.title} width="1200" height="630" loading="eager" fetchpriority="high" decoding="async" />
          </picture>
        </div>

        <aside class="post-cover-side" aria-label="Informações do artigo">
          {postCats.slice(0,1).map(cat => (
            <a href={`/categoria/${toSlug(cat)}`} class="cover-side-cat">
              <i class="fa-solid fa-folder-open"></i>
              <span>{cat}</span>
            </a>
          ))}

          <div class="cover-side-meta">
            <div class="meta-row">
              <i class="fa-regular fa-calendar"></i>
              <span>{formatDate(publishDate)}</span>
            </div>
            <div class="meta-row">
              <i class="fa-regular fa-user"></i>
              <span>{post.authorName}</span>
            </div>
            {post.views > 0 && (
              <div class="meta-row">
                <i class="fa-regular fa-eye"></i>
                <span>{post.views.toLocaleString('pt-BR')} visualizações</span>
              </div>
            )}
            <div class="meta-row">
              <i class="fa-regular fa-clock"></i>
              <span>{Math.max(2, Math.ceil((post.content?.replace(/<[^>]+>/g,'').split(/\s+/).length || 0) / 230))} min de leitura</span>
            </div>
          </div>

          {post.tags?.length > 0 && (
            <div class="cover-side-tags">
              <div class="cover-side-tags-label">
                <i class="fa-solid fa-hashtag"></i> Tópicos
              </div>
              <div class="cover-side-tags-list">
                {post.tags.slice(0, 8).map(tag => (
                  <a href={`/tag/${toSlug(tag)}`} class="cover-side-tag">#{tag}</a>
                ))}
              </div>
            </div>
          )}
        </aside>
      </div>

      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Navegação">
        <a href="/">Início</a>
        {breadcrumbCats.map(cat => (
          <>
            <span aria-hidden="true">›</span>
            <a href={`/categoria/${cat.slug}`}>{cat.name}</a>
          </>
        ))}
        <span aria-hidden="true">›</span>
        <span aria-current="page">{post.title}</span>
      </nav>

      <!-- Ratings (se houver) -->
      {post.ratings && (
        <div class="article-header-row">
          <div class="article-header-right">
            <PostRatings ratings={post.ratings} />
          </div>
        </div>
      )}

      <!-- Title -->
      <h1 class="article-title">{post.title}</h1>

      <!-- Summary -->
      {post.summary && (
        <p style="font-size:1.05rem;color:var(--text-dark);font-weight:600;margin-bottom:1.5rem;border-left:4px solid var(--primary);padding-left:.8rem;line-height:1.6;">
          {post.summary}
        </p>
      )}

      <AuthorCard variant="top" />

      <!-- Spotify podcast player -->
      {spotifyEmbedUrl && (
        <div style="margin:1.5rem 0;">
          <iframe
            src={spotifyEmbedUrl}
            width="100%" height="152" frameborder="0"
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
            loading="lazy"
            style="border-radius:12px;"
          ></iframe>
        </div>
      )}

      <!-- YouTube video player -->
      {post.youtubeVideoId && (
        <div style="margin:1.5rem 0;aspect-ratio:16/9;border-radius:12px;overflow:hidden;">
          <iframe
            width="100%" height="100%"
            src={`https://www.youtube.com/embed/${post.youtubeVideoId}`}
            title="YouTube video"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
            style="display:block;"
          ></iframe>
        </div>
      )}

      <!-- Article body with inline blocks -->
      <div class="article-body">
        {sections.map((section, si) => (
          <>
            {section.content && <Fragment set:html={section.content} />}

            {section.inlineBlocks.map((block, bi) => (
              <RichBlock block={block} blockIdx={si * 100 + bi} />
            ))}

            {section.showAd && inlineAd && (
              <AdBanner ad={inlineAd} position="inline" />
            )}
          </>
        ))}
      </div>

      <!-- WhatsApp Group CTA block -->
      <div class="wpp-cta-block">
        <div class="wpp-cta-icon"><i class="fa-brands fa-whatsapp"></i></div>
        <div class="wpp-cta-content">
          <p class="wpp-cta-title">💬 Gostou? Compartilhe com quem pode se interessar!</p>
          <p class="wpp-cta-body">👥 Entre no grupo para receber novidades em primeira mão:</p>
          <a
            href="https://chat.whatsapp.com/FXw6emOLBtIHOusvzzz1pS"
            target="_blank"
            rel="noopener noreferrer"
            class="wpp-cta-btn"
          >
            <i class="fa-brands fa-whatsapp"></i> Entrar no Grupo WhatsApp
          </a>
        </div>
      </div>

      <!-- Tags -->
      {post.tags?.length > 0 && (
        <div class="article-tags">
          {post.tags.map(tag => (
            <a href={`/tag/${toSlug(tag)}`} class="article-tag">#{tag}</a>
          ))}
        </div>
      )}

      <!-- Share -->
      <div class="share-section">
        <h4>COMPARTILHE ESTE ARTIGO</h4>
        <div class="share-buttons">
          <a
            href={`https://wa.me/?text=${encodeURIComponent(post.title + ' ' + shareUrl)}`}
            target="_blank" rel="noopener" class="share-btn share-whatsapp"
          >
            <i class="fa-brands fa-whatsapp"></i> WhatsApp
          </a>
          <a
            href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`}
            target="_blank" rel="noopener" class="share-btn share-facebook"
          >
            <i class="fa-brands fa-facebook"></i> Facebook
          </a>
          <a
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(shareUrl)}`}
            target="_blank" rel="noopener" class="share-btn share-twitter"
          >
            <i class="fa-brands fa-x-twitter"></i> X
          </a>
          <a
            href={`https://t.me/share/url?url=${encodeURIComponent(shareUrl)}&text=${encodeURIComponent(post.title)}`}
            target="_blank" rel="noopener" class="share-btn share-telegram"
          >
            <i class="fa-brands fa-telegram"></i> Telegram
          </a>
          <button class="share-btn share-copy" data-copy-url={shareUrl} type="button">
            🔗 Copiar link
          </button>
        </div>
      </div>

      <!-- FAQ -->
      {post.faqs && post.faqs.length > 0 && (
        <section class="faq-section" aria-label="Perguntas frequentes">
          <h2>Perguntas Frequentes</h2>
          {faqSideAd && <AdBanner ad={faqSideAd} position="faq-side" />}
          <div class="faq-list">
            {post.faqs.map((faq) => (
              <div class="faq-item">
                <div class="faq-question" role="button" tabindex="0">{faq.question}</div>
                <div class="faq-answer">{faq.answer}</div>
              </div>
            ))}
          </div>
        </section>
      )}

      <AuthorCard variant="bottom" />

      <!-- Post nav prev/next -->
      {(prevPost || nextPost) && (
        <nav class="post-nav" aria-label="Artigos relacionados">
          {prevPost ? (
            <a href={`/${prevPost.slug}`} class="post-nav-item">
              <p class="post-nav-label">← Artigo anterior</p>
              <p class="post-nav-title">{prevPost.title}</p>
            </a>
          ) : <div></div>}
          {nextPost && (
            <a href={`/${nextPost.slug}`} class="post-nav-item post-nav-next">
              <p class="post-nav-label">Próximo artigo →</p>
              <p class="post-nav-title">{nextPost.title}</p>
            </a>
          )}
        </nav>
      )}

      <!-- Reações: like e dislike -->
      <div class="article-reactions">
        <LikeButton postId={post.id} />
      </div>

      <!-- Comentários -->
      <CommentSection postId={post.id} postSlug={post.slug} postTitle={post.title} />

      <!-- Related / Suggested posts -->
      {suggested.length > 0 && (
        <section class="related-section">
          <h3>Veja Também</h3>
          <div class="related-grid">
            {suggested.slice(0, 3).map(p => (
              <PostCard
                title={p.title}
                summary={p.summary}
                slug={p.slug}
                postId={p.id}
                publishedAt={p.publishedAt}
                createdAt={p.createdAt}
                category={p.category}
                categories={p.categories}
                tags={p.tags}
                coverImageUrl={p.coverImageUrl} coverImageKey={p.coverImageKey}
                views={p.views}
                compact={true}
              />
            ))}
          </div>
        </section>
      )}
    </article>

    <!-- ── SIDEBAR ── -->

    <aside class="post-sidebar" aria-label="Barra lateral">
      <!-- Sidebar Ad -->
      {sidebarAd && (
        <div class="sidebar-widget">
          <div class="sidebar-widget-header">Publicidade</div>
          <div class="sidebar-widget-body" style="padding:.8rem">
            <a href={sidebarAd.destinationUrl} target="_blank" rel="noopener sponsored" data-ad-id={sidebarAd.id} class="sidebar-ad">
              <img src={sidebarAd.imageUrl} alt={sidebarAd.title} loading="lazy" />
            </a>
          </div>
        </div>
      )}

      <!-- Categories -->
      {categories.length > 0 && (
        <div class="sidebar-widget">
          <div class="sidebar-widget-header">Categorias</div>
          <div class="sidebar-widget-body">
            <ul class="sidebar-cat-list">
              {categories.map(cat => (
                <li>
                  <a href={`/categoria/${cat.slug}`}>
                    {cat.name}
                    {cat.postCount > 0 && <span class="cat-count">{cat.postCount}</span>}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      )}

      <!-- Suggested posts in sidebar -->
      {suggested.length > 3 && (
        <div class="sidebar-widget">
          <div class="sidebar-widget-header">Mais Lidos</div>
          <div class="sidebar-widget-body">
            <ul class="sidebar-post-list">
              {suggested.slice(3, 8).map(p => (
                <li>
                  <a href={`/${p.slug}`}>{p.title}</a>
                  <p class="sidebar-post-meta">{formatDate(p.publishedAt || p.createdAt)}</p>
                </li>
              ))}
            </ul>
          </div>
        </div>
      )}
    </aside>
  </div>

  <WhatsAppPopup />
</BaseLayout>

<script>
/* ── Terminal blocks + inline code copy ─────────────────────────── */
(function () {
  // ── 1. Transformar <pre><code> em terminal blocks ──────────────
  document.querySelectorAll<HTMLElement>('.article-body pre').forEach(pre => {
    const codeEl = pre.querySelector('code') ?? pre;
    const rawText = codeEl.textContent ?? '';

    const wrap = document.createElement('div');
    wrap.className = 'terminal-block';

    const header = document.createElement('div');
    header.className = 'terminal-header';

    const dotsHtml = `
      <div class="terminal-dots">
        <div class="terminal-dot terminal-dot-red"></div>
        <div class="terminal-dot terminal-dot-yellow"></div>
        <div class="terminal-dot terminal-dot-green"></div>
        <span class="terminal-lang">terminal</span>
      </div>`;

    const copyBtn = document.createElement('button');
    copyBtn.className = 'terminal-copy';
    copyBtn.innerHTML = '<i class="fa-regular fa-copy"></i> Copiar';
    copyBtn.setAttribute('aria-label', 'Copiar código');

    header.innerHTML = dotsHtml;
    header.appendChild(copyBtn);

    const body = document.createElement('div');
    body.className = 'terminal-body';

    // Highlight simples: linhas com $ ou > viram prompt colorido
    const highlighted = rawText.split('\n').map(line => {
      const esc = (s: string) => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      const trimmed = line.trimStart();
      if (trimmed.startsWith('# ') || trimmed.startsWith('// ')) {
        return `<span class="t-comment">${esc(line)}</span>`;
      }
      if (/^\$\s|^>\s/.test(trimmed)) {
        const prompt = trimmed[0];
        const rest = line.replace(/^\s*[$>]\s?/, '');
        const indent = line.length - line.trimStart().length;
        const spaces = ' '.repeat(indent);
        return `${spaces}<span class="t-prompt">${prompt} </span>${esc(rest)}`;
      }
      return esc(line);
    }).join('\n');

    const codeOut = document.createElement('code');
    codeOut.innerHTML = highlighted;
    body.appendChild(codeOut);

    wrap.appendChild(header);
    wrap.appendChild(body);
    pre.replaceWith(wrap);

    // Copy button handler
    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(rawText.trim()).then(() => {
        copyBtn.innerHTML = '<i class="fa-solid fa-check"></i> Copiado!';
        copyBtn.classList.add('copied');
        setTimeout(() => {
          copyBtn.innerHTML = '<i class="fa-regular fa-copy"></i> Copiar';
          copyBtn.classList.remove('copied');
        }, 2200);
      }).catch(() => {
        // fallback clipboard
        const ta = document.createElement('textarea');
        ta.value = rawText.trim();
        ta.style.position = 'fixed'; ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        ta.remove();
        copyBtn.innerHTML = '<i class="fa-solid fa-check"></i> Copiado!';
        copyBtn.classList.add('copied');
        setTimeout(() => {
          copyBtn.innerHTML = '<i class="fa-regular fa-copy"></i> Copiar';
          copyBtn.classList.remove('copied');
        }, 2200);
      });
    });
  });

  // ── 2. Inline <code>: copiar ao clicar + tooltip ──────────────
  document.querySelectorAll<HTMLElement>('.article-body code').forEach(code => {
    if (code.closest('.terminal-block')) return; // já processado

    const text = code.textContent ?? '';
    if (!text.trim()) return;

    code.setAttribute('title', 'Clique para copiar');
    code.addEventListener('click', () => {
      navigator.clipboard.writeText(text.trim()).catch(() => {
        const ta = document.createElement('textarea');
        ta.value = text.trim();
        ta.style.position = 'fixed'; ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        ta.remove();
      });

      const original = code.innerHTML;
      code.classList.add('code-copied');
      code.textContent = '✓ copiado';
      setTimeout(() => {
        code.classList.remove('code-copied');
        code.innerHTML = original;
      }, 1500);
    });
  });
})();
</script>
