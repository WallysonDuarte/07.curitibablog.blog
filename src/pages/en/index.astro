---
// English home — same content as PT-BR but with EN language selector active
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import PostCard from '../../components/PostCard.astro';
import { fetchAllPosts, fetchCategories } from '../../lib/api';

const [allPosts, categories] = await Promise.all([fetchAllPosts(), fetchCategories()]);

const featuredPosts = allPosts.filter(p => p.isFeatured)
  .sort((a, b) => (a.sequence ?? 9999) - (b.sequence ?? 9999));
const fallbackPosts = allPosts.filter(p => !p.isFeatured)
  .sort((a, b) => new Date(b.publishedAt || b.createdAt).getTime() - new Date(a.publishedAt || a.createdAt).getTime());
const carouselSlides = featuredPosts.length >= 3
  ? featuredPosts.slice(0, 8)
  : [...featuredPosts, ...fallbackPosts].slice(0, 8);

const latestPosts = [...allPosts]
  .sort((a, b) => new Date(b.publishedAt || b.createdAt).getTime() - new Date(a.publishedAt || a.createdAt).getTime())
  .slice(0, 6);

const API_BASE = 'https://api.curitibasoftware.com.br';
---

<BaseLayout
  title="CuritibaBlog — Technology, AI and Innovation"
  description="Articles about technology, artificial intelligence, innovation and digital culture. Available in English."
  lang="en"
>
  <SEO
    slot="head"
    title="CuritibaBlog — Technology, AI and Innovation"
    description="Articles about technology, artificial intelligence, innovation and digital culture. Available in English."
    type="website"
  />

  <!-- Latest articles -->
  <section style="max-width:1200px;margin:2rem auto;padding:0 1rem;">
    <h1 style="font-size:1.6rem;font-weight:700;margin-bottom:1.5rem;color:var(--text-primary);">
      Latest Articles
    </h1>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.5rem;">
      {latestPosts.map(p => (
        <PostCard
          title={p.translations?.en?.title || p.title}
          summary={p.translations?.en?.summary || p.summary}
          slug={`en/${p.slug}`}
          postId={p.id}
          publishedAt={p.publishedAt}
          createdAt={p.createdAt}
          category={p.category}
          categories={p.categories}
          tags={p.tags}
          coverImageUrl={p.coverImageUrl}
          coverImageKey={p.coverImageKey}
          views={p.views}
        />
      ))}
    </div>
    <div style="text-align:center;margin-top:2rem;">
      <a href="/" style="color:var(--primary);font-weight:600;text-decoration:none;">
        ← Back to PT-BR version
      </a>
    </div>
  </section>
</BaseLayout>
